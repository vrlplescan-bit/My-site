{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "site-personal",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((req,res)=>{const fs=require('fs');let f='.'+req.url;if(f==='./') f='./index.html';try{const d=fs.readFileSync(f);const m={'html':'text/html','css':'text/css','js':'text/javascript'};res.writeHead(200,{'Content-Type':m[f.split('.').pop()]||'text/plain'});res.end(d);}catch(e){res.writeHead(404);res.end('');}}).listen(3333)"],
      "port": 3333
    }
  ]
}
